# Dashboard Environment Variables
# Copy this file to .env and fill in the values
# .env is gitignored — never commit secrets

# JWT secret for signing auth tokens (use a long random string)
DASHBOARD_SECRET=change-me-use-a-long-random-string

# Admin password (plain text for dev, use bcrypt hash for production)
# Generate a bcrypt hash: node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"
DASHBOARD_ADMIN_PASSWORD=changeme

# Paths (set automatically by docker-compose.yml — override for local dev)
PROJECT_ROOT=/opt/odoo19e-docker
BACKUPS_PATH=/opt/backups

PORT=3000
NODE_ENV=production
